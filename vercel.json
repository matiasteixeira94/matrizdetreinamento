{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/inicio.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/api/(treinamentos|progresso-univm|historico-treinamentos)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=600" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "functions": {
    "api/progresso-univm.js": { "maxDuration": 30 },
    "api/historico-treinamentos.js": { "maxDuration": 30 }
  }
}
